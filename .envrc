use flake

if [ -z "${CARGO_TARGET_DIR:-}" ]; then
  git_common_dir="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)"
  git_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || printf worktree)"
  safe_branch="$(printf '%s' "${git_branch:-worktree}" | tr -cs 'A-Za-z0-9_.-' '_')"
  if [ -n "$git_common_dir" ]; then
    export CARGO_TARGET_DIR="$git_common_dir/cargo-target/$safe_branch"
  fi
fi
